# MentraOS app credentials (get these from console.mentra.glass)
PACKAGE_NAME=com.yourname.yourapp
MENTRAOS_API_KEY=your_api_key_here

# Local app server port. The MentraOS console "Public URL" should
# point an ngrok (or other) tunnel at this port.
PORT=3000

# WHIP publish URL the glasses POST WebRTC offers to.
# IP MUST be your laptop's current LAN IP (NOT 127.0.0.1, NOT the ngrok host),
# because the glasses connect to MediaMTX directly over WiFi.
# Find it with `ipconfig` (Windows) or `ifconfig` / `ip addr` (macOS/Linux).
WHIP_URL=http://192.168.1.42:8889/live/glasses/whip

# WHEP pull URL for python -m apps.viewer (localhost is correct on the laptop).
WHEP_URL=http://127.0.0.1:8889/live/glasses/whep

# TTS and transcript SSE endpoints (defaults derive from PORT above).
# SPEAK_URL=http://127.0.0.1:3000/speak
# TRANSCRIPT_URL=http://127.0.0.1:3000/transcripts

# If true, viewer reads cloud transcripts from the Bun server instead of local Soniox.
USE_MENTRA_TRANSCRIPTION=false

# Print partial Soniox tokens to stdout while transcribing.
SHOW_INTERIM=false

# Append-only log of transcript update events (gitignored).
TRANSCRIPT_LOG_PATH=transcript_updates.log

# Soniox real-time speech-to-text (get key from soniox.com)
SONIOX_API_KEY=your_soniox_api_key_here

# Anthropic API key for end-of-session name resolution (console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Your name — used to label your speech in the transcript instead of "User"
USER_NAME=Your Name

# Enable or disable the proactivity agent (1/true/yes = on; 0/false/no = off).
PROACTIVITY_ENABLED=1

# Classifier probability gate — sentences below this never reach Claude.
GLASSES_GATE_THRESHOLD=0.25

# Text spoken when pressing p in the viewer (speaker check).
DEFAULT_PHRASE=Reflections speaker check

# Port for python -m proactivity.dashboard
DASHBOARD_PORT=8766

# Default location bias for maps tools (places_search, directions).
# Override with your actual coordinates — the shipped defaults (0, 0)
# will return ocean results from Google Maps until you change them.
DEFAULT_LOCATION_NAME=Example City, CA
DEFAULT_LOCATION_LAT=0.0
DEFAULT_LOCATION_LON=0.0
DEFAULT_LOCATION_RADIUS_M=5000

# Google Maps API key for the proactivity agent's places_search,
# place_details, and directions tools. Create a key at
# console.cloud.google.com → APIs & Services → Credentials, then enable
# "Places API (New)" and "Directions API" on the same project. Billing
# must be enabled on the project (both APIs have a free monthly tier).
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Calendar OAuth credentials for the proactivity agent's
# list_calendar_events, find_calendar_event, and create_calendar_event
# tools. Calendar uses OAuth (not a plain API key like Maps).
#
# One-time setup:
#   1. In console.cloud.google.com on the same project as Maps, enable
#      the "Google Calendar API".
#   2. Configure an OAuth consent screen (External, your own email as
#      the only test user — keeps it in "Testing" mode forever, no
#      verification needed).
#   3. Create an OAuth Client ID of type "Desktop app". Copy the
#      client ID and client secret into the two vars below.
#   4. Run `python -m proactivity.calendar_auth`. It opens a browser,
#      walks you through the consent flow, and prints a refresh token
#      — paste that as GOOGLE_OAUTH_REFRESH_TOKEN.
GOOGLE_OAUTH_CLIENT_ID=your_oauth_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_oauth_client_secret_here
GOOGLE_OAUTH_REFRESH_TOKEN=your_refresh_token_here

# Hugging Face model ID for the proactivity LoRA adapter (classifier gate).
# Default: rushilsaraf/qwen3-actionable-v2-adapter
# Prefetch: ./scripts/download_lora.sh  (or .ps1 on Windows)
REFLECTIONS_LORA_MODEL_ID=rushilsaraf/qwen3-actionable-v2-adapter
