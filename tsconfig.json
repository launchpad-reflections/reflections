{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./apps/camera-server/src",
    "lib": ["ES2022"],
    "types": ["bun-types"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./apps/camera-server/src/*"]
    }
  },
  "include": ["apps/camera-server/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
